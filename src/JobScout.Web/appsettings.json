{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "JobScout": "Data Source=jobscout.db"
  },
  "//Secrets": "API keys (Adzuna AppId/AppKey, SerpApi/TheirStack ApiKey) are NOT stored here — set them via 'dotnet user-secrets' so they never reach the repo. Only non-secret settings live below.",
  "Adzuna": {
    "Country": "us"
  },
  "SerpApi": {
    "Location": "United States"
  },
  "TheirStack": {
    "MaxAgeDays": 30,
    "Limit": 50
  },
  "Crawl": {
    "IntervalMinutes": 360,
    "TopN": 10,
    "Boards": [
      { "Source": "Greenhouse", "Feed": "solarwinds" },
      { "Source": "Greenhouse", "Feed": "newrelic" },
      { "Source": "Greenhouse", "Feed": "godaddy" },
      { "Source": "Greenhouse", "Feed": "datadog" },
      { "Source": "Greenhouse", "Feed": "twilio" },
      { "Source": "Greenhouse", "Feed": "epicgames" },
      { "Source": "Greenhouse", "Feed": "nintex" },
      { "Source": "Jobicy", "Feed": ".net" },
      { "Source": "Adzuna", "Feed": ".net developer" },
      { "Source": "GoogleJobs", "Feed": ".net developer" },
      { "Source": "TheirStack", "Feed": ".NET" }
    ]
  }
}
